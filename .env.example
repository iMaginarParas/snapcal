# Port for the FastAPI server to listen on (defaults to 3000)
PORT=3000

# Google Gemini API key for running food image analysis and mock generation
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase API credentials
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_public_key_here
# Optional: service role key if backend performs admin operations bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# FatSecret API credentials (for barcode scan & branded food lookups)
FATSECRET_CLIENT_ID=your_fatsecret_client_id_here
FATSECRET_CLIENT_SECRET=your_fatsecret_client_secret_here

# USDA FoodData Central API key
USDA_API_KEY=your_usda_api_key_here

# CORS configuration: Comma-separated list of allowed origins. Use '*' or leave blank to allow all.
ALLOWED_ORIGINS=*
