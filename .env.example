# FitSnap AI - Backend Environment Variables Example
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fitsnap

# Redis (used for Celery and Caching)
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=generate-a-safe-secret-key-here

# Supabase (Storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key
SUPABASE_BUCKET=meal-images

# Firebase (Push Notifications)
# In production, this can be the full JSON string
FIREBASE_SERVICE_ACCOUNT=

# Monitoring & Analytics (Optional)
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# App
PORT=8000
ENVIRONMENT=development
